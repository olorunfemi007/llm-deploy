FROM ubuntu:24.04 AS build

RUN apt-get update && apt-get install -y \
    build-essential cmake git libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/ggml-org/llama.cpp.git /llama.cpp

WORKDIR /llama.cpp

RUN cmake -B build \
    -DGGML_RPC=ON \
    -DLLAMA_CURL=ON \
    -DBUILD_SHARED_LIBS=OFF \
    -DCMAKE_BUILD_TYPE=Release \
    && cmake --build build --target llama-server --target rpc-server -j$(nproc)

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    libgomp1 libcurl4 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build /llama.cpp/build/bin/llama-server /app/llama-server
COPY --from=build /llama.cpp/build/bin/rpc-server /app/rpc-server

ENV LD_LIBRARY_PATH=/app
ENV LLAMA_ARG_HOST=0.0.0.0

ENTRYPOINT ["/app/llama-server"]
